# TheSportsDB API key (defaults to free key "3" if not set)
VITE_SPORTSDB_API_KEY=3

# Supabase project credentials (required — use one of the key variants)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
# Or if Supabase provides a publishable key instead:
# VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-key-here
